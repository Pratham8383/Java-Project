export interface Subject {
  id: number;
  name: string;
  examDate: string;
  priority: number;
}

export interface StudyTask {
  id: number;
  subjectId: number;
  subjectName: string;
  date: string;
  durationMinutes: number;
  isCompleted: boolean;
}

export interface ScheduleDay {
  date: string;
  tasks: StudyTask[];
}

export interface Todo {
  id: number;
  text: string;
  isCompleted: boolean;
}
